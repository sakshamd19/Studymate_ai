# ============================================================
# StudyMate AI — Environment Configuration
# Microsoft Agents League Hackathon 2026
# ============================================================

# ---- PRIMARY: Microsoft Foundry IQ ----
# Get from: ai.azure.com → your project → Overview
FOUNDRY_API_KEY=your-foundry-api-key-here
FOUNDRY_ENDPOINT=https://studymate-ai-resource.services.ai.azure.com/api/projects/studymate-ai

# ---- SECONDARY: Azure OpenAI via Foundry ----
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://studymate-ai-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- GitHub Models (Azure OpenAI backed — Priority 3) ----
# Free with GitHub Student Pack — get token at github.com/settings/tokens
# Create fine-grained token → Account permissions → Models → Read-only
GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL=openai/gpt-4.1-mini

# ---- EMERGENCY FALLBACK: Groq (free — no credit card) ----
# Free key at: console.groq.com — takes 2 minutes to set up
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- App ----
DEBUG=false
